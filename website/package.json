    "eslint": "9.39.4",
    "prettier-plugin-svelte": "3.5.1",
    "prettier-plugin-tailwindcss": "0.7.2",
    "prettier": "3.8.1",
    "svelte-check": "4.4.5",
    "svelte": "5.55.0",
    "tailwindcss": "4.2.2",
