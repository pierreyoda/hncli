    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-svelte": "3.19.0",
    "eslint": "9.39.4",
    "prettier-plugin-svelte": "4.1.1",
    "prettier-plugin-tailwindcss": "0.8.0",
    "prettier": "3.8.4",
    "svelte-check": "4.6.0",
    "svelte": "5.56.3",
    "tailwindcss": "4.3.1",
